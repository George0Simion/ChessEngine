# Copy to .env for local development (loaded automatically by python-dotenv).
# In production (Render), set these in the dashboard / Blueprint instead.

# Flask session + default JWT signing secret. Use a long random string.
SECRET_KEY=dev-secret-change-in-production

# Dedicated JWT signing secret. Falls back to SECRET_KEY if unset.
# MUST be identical for the web app and the multiplayer service.
JWT_SECRET_KEY=dev-secret-change-in-production

# Production database. If unset, the app uses a local SQLite file.
# Render Postgres looks like: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=postgresql://user:pass@host:5432/chessmate

# Set to "development" to enable Flask debug for `python app.py`.
FLASK_ENV=development

# Where persistent runtime files (SQLite fallback DB + analysis cache) are stored.
# Defaults to the Flask instance folder (./instance). On Render, point this at a
# mounted disk if you want the analysis cache / SQLite DB to survive restarts.
# DATA_DIR=/var/data

# Local dev ports.
PORT=5000
MP_PORT=8000

# Public WebSocket URL of the multiplayer service (production, cross-service).
# Local dev derives this automatically from MP_PORT, so leave it unset locally.
# MP_WS_URL=wss://chessmate-mp.onrender.com/ws
